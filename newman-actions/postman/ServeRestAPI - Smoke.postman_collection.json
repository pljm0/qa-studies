  "item": [
    {
      "name": "cadastrar usuarios",
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "pm.test(\"Status deve ser 201\", () =>{\r",
              "    pm.response.to.have.status(201);\r",
              "});\r",
              "\r",
              "const json = pm.response.json();\r",
              "pm.collectionVariables.set(\"idUsuarioA\", pm.response.json()._id);\r",
              "\r",
              "pm.test(\"Deve retornar uma mensagem de sucesso e id\", () => { \r",
              "    pm.expect(json.message).to.eql(\"Cadastro realizado com sucesso\");\r",
              "    pm.expect(json._id).to.not.be.empty;\r",
              "});"
            ],
            "type": "text/javascript",
            "packages": {},
            "requests": {}
          }
        },
        {
          "listen": "prerequest",
          "script": {
            "exec": [
              "pm.collectionVariables.set(\"nomeUsuario\", \"Usuario_\" + Date.now());"
            ],
            "type": "text/javascript",
            "packages": {},
            "requests": {}
          }
        }
      ],
      "request": {
        "auth": {
          "type": "noauth"
        },
        "method": "POST",
        "header": [],
        "body": {
          "mode": "raw",
          "raw": "{\r\n  \"nome\": \"{{nomeUsuario}}\",\r\n  \"email\": \"{{nomeUsuario}}@gmail.com\",\r\n  \"password\": \"teste\",\r\n  \"administrador\": \"true\"\r\n}",
          "options": {
            "raw": {
              "language": "json"
            }
          }
        },
        "url": {
          "raw": "{{baseUrl}}/usuarios",
          "host": [
            "{{baseUrl}}"
          ],
          "path": [
            "usuarios"
          ]
        }
      },
      "response": []
    },
    {
      "name": "login",
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "pm.test(\"Status code deve ser 200\", function () {\r",
              "    pm.response.to.have.status(200);\r",
              "});\r",
              "\r",
              "pm.test(\"Deve retornar mensagem de sucesso\", function () {\r",
              "    const json = pm.response.json();\r",
              "    pm.expect(json.message).to.eql(\"Login realizado com sucesso\");\r",
              "});\r",
              "\r",
              "pm.test(\"Deve retornar um token de autenticação\", function () {\r",
              "    const json = pm.response.json();\r",
              "    pm.expect(json.authorization).to.exist;\r",
              "    pm.collectionVariables.set(\"token\", json.authorization);\r",
              "});"
            ],
            "type": "text/javascript",
            "packages": {},
            "requests": {}
          }
        }
      ],
      "protocolProfileBehavior": {
        "disabledSystemHeaders": {}
      },
      "request": {
        "method": "POST",
        "header": [],
        "body": {
          "mode": "raw",
          "raw": "{\r\n  \"email\": \"{{nomeUsuario}}@gmail.com\",\r\n  \"password\": \"teste\"\r\n}",
          "options": {
            "raw": {
              "language": "json"
            }
          }
        },
        "url": {
